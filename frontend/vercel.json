{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://task-management-system-backend-z9y4.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://task-management-system-backend-z9y4.onrender.com/socket.io/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
