# Resend email (Taskora) — RESEND_API_KEY is required on Render
RESEND_API_KEY=re_paste_your_key_here
# Optional. If omitted, backend uses onboarding@resend.dev (Resend sandbox — limited recipients)
EMAIL_FROM=Taskora <noreply@vendra.best>
FRONTEND_URL=https://taskora.vendra.best
# Optional override for email header logo (defaults to FRONTEND_URL/taskora-email-logo.png)
# EMAIL_LOGO_URL=https://taskora.vendra.best/taskora-email-logo.png

# Auth
JWT_SECRET=your_long_random_secret_here
PORT=5000

# CORS (comma-separated frontend URLs)
CLIENT_ORIGIN=https://taskora.vendra.best,https://task-management-system-pi-five.vercel.app,http://localhost:5173
API_BASE_URL=https://task-management-system-backend-z9y4.onrender.com

# Database — recommended on Render: use split vars (avoids @ in password breaking URLs)
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.pxivckosjllfhzpzbqac
DB_PASSWORD=your_supabase_password_here
DB_NAME=postgres
DB_SSL=true
SUPABASE_POOLER_HOST=aws-1-ap-southeast-1.pooler.supabase.com

# Alternative: single URL (encode special chars in password, e.g. @ as %40)
# DATABASE_URL=postgresql://postgres.pxivckosjllfhzpzbqac:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
